# Cosmic Crunch — Supabase configuration
# Copy this file to `.env` and fill in the values from your Supabase project
# (Project Settings → API). Only the PUBLIC anon key belongs in the frontend.
#
# NEVER put the service_role key in a VITE_ variable — it would be shipped to
# the browser and grant full database access.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
